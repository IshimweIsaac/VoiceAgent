# =============================================================================
# VoiceAgent — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Google Gemini API -------------------------------------------------------
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- Twilio ------------------------------------------------------------------
# Find these in your Twilio Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./voice_agent.db

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=random-64-char-secret-for-sessions

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=32-byte-base64-key-for-oauth-tokens

# --- Google OAuth (for Google Calendar integration) ---------------------------
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=https://yourdomain.com/dashboard/calendar/callback

# --- Optional ----------------------------------------------------------------
LOG_LEVEL=INFO
DEBUG=false
MAX_CONCURRENT_CALLS=5
